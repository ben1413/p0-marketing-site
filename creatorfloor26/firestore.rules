rules_version = '2';

// Deploy: firebase deploy --only firestore:rules
// (from repo root; requires Firebase CLI and firebase.json)

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // --- Projects (client CRUD) ---
    match /cf_projects/{projectDocId} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.coreProjectId is string
        && request.resource.data.name is string;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // --- Kanban per user + Core project id (client CRUD) ---
    // Path encodes owner so rules stay simple (no orphan-doc reads).
    match /users/{userId}/cf_boards/{coreProjectId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // --- Builder soft buckets & checkpoints: written only by Firebase Admin (API routes) ---
    match /cf_builder_personal/{docId} {
      allow read, write: if false;
    }
    match /cf_builder_team/{docId} {
      allow read, write: if false;
    }
    match /cf_builder_checkpoints/{docId} {
      allow read, write: if false;
    }

    // --- Telemetry: written only by server (Admin SDK) ---
    match /cf_telemetry_events/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
