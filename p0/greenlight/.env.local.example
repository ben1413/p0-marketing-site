# -------------------------------------------------------
# Greenlight — environment variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to source control
# -------------------------------------------------------

# Core API
# Your Project0 Core instance URL
CORE_URL=https://your-core-instance.vercel.app

# Admin API key — NEVER expose this to the browser
# Must have admin role for approve/deploy/rollback operations
GREENLIGHT_CORE_API_KEY=your_admin_key_here

# The game this Greenlight instance manages
GREENLIGHT_GAME_ID=your_game_id_here

# -------------------------------------------------------
# Demo mode (set to "true" to use Nexus Online seed data)
# No Core connection required in demo mode
# -------------------------------------------------------
GREENLIGHT_DEMO_MODE=false

# -------------------------------------------------------
# Firebase Auth (for operator sign-in in production)
# Enable Email/Password in Firebase Auth console
# Create operators via Firebase Auth console or Admin SDK
# -------------------------------------------------------

# Option A: JSON config blob (recommended)
# NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"..."}

# Option B: individual vars
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -------------------------------------------------------
# MCP server (mcp/ directory)
# -------------------------------------------------------
P0_API_KEY=your_admin_key_here
P0_CORE_URL=https://your-core-instance.vercel.app
GREENLIGHT_GAME_ID=your_game_id_here
