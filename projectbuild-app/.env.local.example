# ─── ProjectBuild → Core connection ────────────────────────────────────────────
#
# Full reference: core/docs/PROJECTBUILD_CORE_ENV.md
#
# Step 1: Run Core  →  cd ~/Projects/p0/core && npm run dev
#          Note the port Core starts on (e.g. http://localhost:3000)
#
# Step 2: Fill in the three required vars below
#
# Step 3: Register an agent if you don't have one yet:
#   curl -X POST http://localhost:3000/api/v1/agents/register \
#     -H "x-dev-bypass: <DEV_BYPASS_SECRET>" \
#     -H "Content-Type: application/json" \
#     -d '{"name":"Build Agent","persona":"Helpful assistant","jobTitle":"Assistant","allowedActions":["read_brain"]}'
#   Copy the returned "id" into P0_CORE_AGENT_ID below.
#
# ────────────────────────────────────────────────────────────────────────────────

# Base URL of Core — all calls go to {P0_CORE_BASE_URL}/api/v1/...
# Local:   URL Core prints on startup (e.g. http://localhost:3000)
# Staging: your deployed Core URL (e.g. https://core.yourcompany.com)
P0_CORE_BASE_URL=http://localhost:3000

# Auth — use ONE of the following:
#
#   Production / staging:
#     P0_CORE_API_KEY=p0_xxx   (created via POST /api/v1/keys on Core with role agent_runner or admin)
#
#   Local dev only:
#     DEV_BYPASS_SECRET=<same value set in Core's .env.local DEV_BYPASS_SECRET>
#     (Core sends x-dev-bypass header; only accepted when NODE_ENV=development + host is localhost)
#
P0_CORE_API_KEY=
DEV_BYPASS_SECRET=

# Default agent ID — at least one required for run/simple and run/meeting
# Get it from: POST /api/v1/agents/register  OR  GET /api/v1/agents/list
P0_CORE_AGENT_ID=

# Additional per-persona agent IDs (optional — add as many as your project needs)
# P0_CORE_AGENT_PM=ag_xxx
# P0_CORE_AGENT_ENG=ag_xxx
# P0_CORE_AGENT_DESIGN=ag_xxx

# ─── Firebase ───────────────────────────────────────────────────────────────────
# Get these from Firebase console → Project settings → Your apps → Web app config
# Falls back to the Solo project if not set (dev only)
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ─── Cost guardrails (set on Core server — listed here for reference only) ──────
# These env vars live in Core's .env, not here. Documented so you know what limits apply.
#
# P0_MAX_TURNS_PER_MEETING=50       Max agent turns before Core returns 429 (stored meetings only)
# P0_MAX_OUTPUT_TOKENS=4096         max_tokens passed to LLM per run (0 = provider default)
# P0_MAX_INPUT_TOKENS=0             Truncate user message if input tokens exceed this (0 = no limit)
# P0_DEFAULT_MODEL=                 Override agent model for all routine turns
# P0_ESCALATION_MODEL=              Model used when escalation keywords found in prompt
# P0_ESCALATION_KEYWORDS=           Comma-separated keywords that trigger escalation model
